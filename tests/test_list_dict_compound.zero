(cli_app
	(defun one ()
		(type_hint return "string")
		(return "hi")
	)
	(print "list with compound element:" (list (call one) "b"))
	(print "dict with compound value:" (dict ("k" (call one))))
	(let (l (list (call one) "b"))
		(print "let list with compound element:" l)
	)
	(let (d (dict ("k" (call one))))
		(print "let dict with compound value:" d)
	)
)
