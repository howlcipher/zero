(cli_app
  (defun add (a b)
    (type_hint a "int")
    (type_hint b "int")
    (type_hint return "int")
    (return (+ a b))
  )

  (defun add_via_call (a b)
    (type_hint a "int")
    (type_hint b "int")
    (type_hint return "int")
    (return (call add a b))
  )

  (let (result (call add 2 3))
    (if (!= result 5)
      (print "Error: expected 5 got" result)
      (print "ok: add(2,3) ==" result)
    )
  )

  (let (result2 (call add_via_call 4 5))
    (if (!= result2 9)
      (print "Error: expected 9 got" result2)
      (print "ok: add_via_call(4,5) ==" result2)
    )
  )
)
