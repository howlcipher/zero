(cli_app
  (defun add ((a int) (b int)) int
    (return (+ a b))
  )

  (defun mul (a b)
    (type_hints (a int) (b int) (return int))
    (return (* a b))
  )

  (let (n (to_int "42"))
    (let (f (to_float "3.14"))
      (let (s (to_string n))
        (do
          (print (call add n 1))
          (print (call mul 2 3))
          (print s)
        )
      )
    )
  )
)
