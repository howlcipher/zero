(cli_app
	(print "list in print arg:" (list "a" "b"))
	(print "dict in print arg:" (dict ("k1" "v1") ("k2" "v2")))
	(defun make_list ()
		(type_hint return "[]string")
		(return (list "x" "y" "z"))
	)
	(defun make_dict ()
		(type_hint return "map[string]string")
		(return (dict ("k" "v")))
	)
	(print "list from return:" (call make_list))
	(print "dict from return:" (call make_dict))
	(let (l (list "a" "b"))
		(print "list still works as let value:" l)
	)
	(let (d (dict ("a" "1")))
		(print "dict still works as let value:" d)
	)
)
