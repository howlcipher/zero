(cli_app
  (try_let (content (read_file "names.txt"))
    (catch err (print "Error: could not read names.txt"))
    (do
      (let (lines (str_split (call string content) "\n"))
        (for line lines
          (if (!= line "")
            (print "Hello," line)
            (print "")
          )
        )
      )
    )
  )
)
